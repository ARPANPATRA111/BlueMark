rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Cache the user doc read in a local variable to avoid redundant reads.
    function userData() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function hasTenant(tenantId) {
      let user = userData();
      return isSignedIn()
        && user != null
        && user.tenantId == tenantId
        && user.isActive != false;
    }

    function hasRole(role) {
      let user = userData();
      return user != null && user.role == role;
    }

    function hasAnyRole(roles) {
      let user = userData();
      return user != null && user.role in roles;
    }

    function isSelfUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isActiveRole(roles) {
      let user = userData();
      return user != null
        && user.role in roles
        && user.isActive != false;
    }

    match /users/{userId} {
      allow create: if isSelfUser(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'tenantId', 'role', 'email', 'displayName'])
        && request.resource.data.tenantId is string
        && request.resource.data.tenantId.size() > 0
        && request.resource.data.tenantId.size() <= 50
        && request.resource.data.email is string
        && request.resource.data.displayName is string;

      allow read: if isSelfUser(userId)
        || (resource != null
          && hasTenant(resource.data.tenantId)
          && hasRole('admin'));

      allow update: if isSelfUser(userId)
        || (resource != null
          && hasTenant(resource.data.tenantId)
          && hasRole('admin'));

      allow delete: if false;
    }

    match /tenants/{tenantId} {
      allow read: if hasTenant(tenantId);
      allow write: if false;

      match /students/{rollNumber} {
        allow read: if hasTenant(tenantId)
          && (
            isActiveRole(['admin', 'teacher'])
            || (hasRole('student') && userData().rollNumber == rollNumber)
          );

        allow create, update: if hasTenant(tenantId)
          && (
            isActiveRole(['admin', 'teacher'])
            || (hasRole('student') && request.resource.data.linkedUserId == request.auth.uid)
          );

        allow delete: if hasTenant(tenantId) && hasRole('admin');
      }

      match /attendance/{attendanceId} {
        allow read: if hasTenant(tenantId) && isActiveRole(['admin', 'teacher']);

        allow create, update: if hasTenant(tenantId)
          && isActiveRole(['admin', 'teacher'])
          && request.resource.data.keys().hasAll(['sessionId', 'classId', 'createdAt', 'students'])
          && request.resource.data.tenantId == tenantId;

        allow delete: if false;
      }

      match /attendance_receipts/{receiptId} {
        allow read: if hasTenant(tenantId)
          && (
            isActiveRole(['admin', 'teacher'])
            || (hasRole('student') && resource.data.rollNumber == userData().rollNumber)
          );

        allow create, update: if hasTenant(tenantId) && isActiveRole(['admin', 'teacher']);
        allow delete: if false;
      }

      match /active_sessions/{classId} {
        allow read: if hasTenant(tenantId);
        allow create, update: if hasTenant(tenantId) && isActiveRole(['admin', 'teacher']);
        allow delete: if hasTenant(tenantId) && isActiveRole(['admin', 'teacher']);
      }

      match /classes/{classId} {
        allow read: if hasTenant(tenantId);
        allow create, update: if hasTenant(tenantId) && isActiveRole(['admin', 'teacher']);
        allow delete: if hasTenant(tenantId) && hasRole('admin');
      }
    }
  }
}
